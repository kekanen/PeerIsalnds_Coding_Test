# LLM Provider Configuration
LLM_PROVIDER=openai

# ── Option 1: Direct OpenAI ───────────────────────────────────────────────────
# Native OpenAI key (sk-proj-...)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_API_BASE=                          # leave empty for direct OpenAI
OPENAI_MODEL=gpt-4o-mini                  # use native model name (no vendor prefix)
OPENAI_TEMPERATURE=0.3

# ── Option 2: OpenRouter ─────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-or-...
# OPENAI_API_BASE=https://openrouter.ai/api/v1
# OPENAI_MODEL=openai/gpt-4o-mini

# ── Option 3: Azure OpenAI ───────────────────────────────────────────────────
# LLM_PROVIDER=azure_openai
# AZURE_OPENAI_API_KEY=your-azure-key
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
# AZURE_OPENAI_API_VERSION=2024-02-15-preview

# ── Option 4: Anthropic Claude ───────────────────────────────────────────────
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=your-anthropic-key
# ANTHROPIC_MODEL=claude-sonnet-4-5

# LLM Configuration
MAX_TOKENS=4096
MAX_TOKENS_PER_REQUEST=4096
TEMPERATURE=0.3

# Application Configuration
OUTPUT_DIR=./output
LOG_LEVEL=INFO

# Architecture Preferences
ARCHITECTURE_PATTERN=clean_architecture
NODEJS_FRAMEWORK=express
ORM_PREFERENCE=typeorm

# RAG / ChromaDB (optional — defaults work out of the box)
ENABLE_RAG=true
CHROMA_PERSIST_DIR=./.chroma_db
RAG_TOP_K=3
